# ============================================
# BRACERIA SANNICANDRO - Variabili d'Ambiente
# ============================================
# Copia questo file come .env.local e compila i valori
# NON committare mai .env.local su Git!

# --- MongoDB Atlas ---
# Ottieni la stringa di connessione da: MongoDB Atlas > Connect > Drivers
MONGODB_URI=mongodb+srv://<utente>:<password>@cluster0.xxxxx.mongodb.net/braceria?retryWrites=true&w=majority

# --- NextAuth (Autenticazione Admin) ---
# Genera una stringa casuale sicura: openssl rand -base64 32
NEXTAUTH_SECRET=cambia-questo-con-una-stringa-casuale-sicura
# In produzione: https://tuodominio.vercel.app
NEXTAUTH_URL=http://localhost:3000

# --- Pusher (Real-time cucina) ---
# Registrati su https://pusher.com (free tier: 200k messaggi/giorno)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu
# Variabili pubbliche (accessibili dal browser)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# --- CallMeBot (Notifiche WhatsApp) ---
# Istruzioni: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# 1. Aggiungi +34 644 91 87 47 ai tuoi contatti come "CallMeBot"
# 2. Invia "I allow callmebot to send me messages" su WhatsApp
# 3. Riceverai la tua API key
CALLMEBOT_PHONE=39XXXXXXXXXX
CALLMEBOT_API_KEY=

# --- Admin Credentials (Solo per seed iniziale) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CambiaQuestaPrima123!

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RISTORANTE_NOME=Braceria Sannicandro
NEXT_PUBLIC_RISTORANTE_CITTA=Sannicandro di Bari
